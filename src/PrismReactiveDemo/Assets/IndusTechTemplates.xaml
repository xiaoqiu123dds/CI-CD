    <!-- ================================================================================================== -->
    <!-- INDUSTRITECH THEME (Dark Slate / Factory Unit A Style) -->
    <!-- ================================================================================================== -->
    
    <!-- 1. COLORS / 颜色 -->
    <Color x:Key="BgMainColor">#0F172A</Color>       <!-- Dark Slate Blue -->
    <Color x:Key="BgCardColor">#1E293B</Color>       <!-- Lighter Slate -->
    <Color x:Key="BorderColor">#334155</Color>       <!-- Border Grey-Blue -->
    <Color x:Key="AccentColor">#06B6D4</Color>       <!-- Industrial Cyan -->
    <Color x:Key="AccentLightColor">#22D3EE</Color>  <!-- Light Cyan (Hover) -->
    
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>  <!-- Almost White -->
    <Color x:Key="TextSecondaryColor">#94A3B8</Color><!-- Cool Grey -->
    
    <Color x:Key="StatusGreenColor">#22C55E</Color>
    <Color x:Key="StatusAmberColor">#F59E0B</Color>
    <Color x:Key="StatusRedColor">#EF4444</Color>

    <!-- 2. BRUSHES / 画刷 -->
    <SolidColorBrush x:Key="BgMainBrush" Color="{StaticResource BgMainColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" po:Freeze="True"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" po:Freeze="True"/>
    
    <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreenColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="StatusAmberBrush" Color="{StaticResource StatusAmberColor}" po:Freeze="True"/>
    <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRedColor}" po:Freeze="True"/>

