<presentation:PrismReactiveWindow x:Class="PrismReactiveDemo.Modules.Shell.Views.ShellWindow"
                                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                  xmlns:prism="http://prismlibrary.com/"
                                  xmlns:presentation="clr-namespace:PrismReactiveDemo.Presentation.Core"
                                  xmlns:core="clr-namespace:PrismReactiveDemo.Core.Constants"
                                  xmlns:vm="clr-namespace:PrismReactiveDemo.Modules.Shell.ViewModels"
                                  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                                  x:TypeArguments="vm:ShellViewModel"
                                  prism:ViewModelLocator.AutoWireViewModel="True"
                                  mc:Ignorable="d"
                                  Title="Nexus Elite IndusTech"
                                  Width="1280"
                                  Height="800"
                                  WindowStartupLocation="CenterScreen"
                                  WindowStyle="None"
                                  AllowsTransparency="True"
                                  Background="Transparent">

    <!-- 窗口边框样式 / Window Chrome Settings -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- 主容器 (IndusTech 主题背景) / Main Container -->
    <Border Background="{DynamicResource BgMainBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <!-- ============================================ -->
            <!-- CUSTOM TITLE BAR / 自定义标题栏 -->
            <!-- ============================================ -->
            <Grid Height="40" VerticalAlignment="Top" Background="{DynamicResource BgCardBrush}" Panel.ZIndex="100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 拖动代理区域绑定鼠标拖动 -->
                <Border Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                <!-- 应用图标和标题 / App Icon and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0" IsHitTestVisible="False">
                    <iconPacks:PackIconMaterial Kind="CubeOutline" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 窗口控制按钮组 / Window Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{DynamicResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化 / Minimize">
                        <Path Data="{DynamicResource MinimizeIcon}" Style="{DynamicResource WindowIconStyle}"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{DynamicResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化 / Maximize">
                        <Path x:Name="MaximizeIcon" Data="{DynamicResource MaximizeIcon}" Style="{DynamicResource WindowIconStyle}"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{DynamicResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭 / Close">
                        <Path Data="{DynamicResource CloseIcon}" Style="{DynamicResource WindowIconStyle}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============================================ -->
            <!-- MAIN CONTENT AREA / 主业务内容区域 -->
            <!-- ============================================ -->
            <Grid Margin="0,40,0,0">
                <Grid.ColumnDefinitions>
                    <!-- 左侧边栏 / Left Sidebar -->
                    <ColumnDefinition Width="240" />
                    <!-- 右侧主内容 / Right Content -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Navigation Items -->
                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <!-- Dashboard Nav 项 -->
                            <RadioButton x:Name="DashboardNav" GroupName="SidebarNav" Style="{DynamicResource SidebarNavRadioButtonStyle}" IsChecked="True" Content="Dashboard" Tag="ViewDashboard"/>
                            <!-- Editor Nav 项 -->
                            <RadioButton x:Name="EditorNav" GroupName="SidebarNav" Style="{DynamicResource SidebarNavRadioButtonStyle}" Content="Editor" Tag="FileDocumentEdit"/>
                        </StackPanel>
                        
                        <!-- (不可见的隐藏按钮，用于后台命令绑定) -->
                        <Button x:Name="DashboardButton" Visibility="Collapsed" />
                        <Button x:Name="EditorButton" Visibility="Collapsed" />

                        <!-- Status Area at bottom of sidebar -->
                        <StackPanel Grid.Row="2" Margin="16" VerticalAlignment="Bottom">
                            <TextBlock Text="状态 / Status" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LatestError}" Foreground="{DynamicResource StatusRedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Region Wrapper (Stitch concept) -->
                <Border Grid.Column="1" Background="{DynamicResource BgMainBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Top Header Bar displaying status -->
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Top Header Bar -->
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource BgCardBrush}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                                <iconPacks:PackIconMaterial Kind="ConsoleLine" Foreground="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusText, StringFormat='System Log: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Content Control -->
                        <ContentControl Grid.Row="1" prism:RegionManager.RegionName="{x:Static core:RegionNames.MainRegion}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</presentation:PrismReactiveWindow>
