<presentation:PrismReactiveView x:Class="PrismReactiveDemo.Modules.Dashboard.Views.DashboardView"
                               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:prism="http://prismlibrary.com/"
                               xmlns:presentation="clr-namespace:PrismReactiveDemo.Presentation.Core"
                               xmlns:vm="clr-namespace:PrismReactiveDemo.Modules.Dashboard.ViewModels"
                               xmlns:design="clr-namespace:PrismReactiveDemo.Modules.Dashboard.Design"
                               xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                               x:TypeArguments="vm:DashboardViewModel"
                               prism:ViewModelLocator.AutoWireViewModel="True"
                               d:DataContext="{d:DesignInstance Type=design:DashboardDesignViewModel, IsDesignTimeCreatable=True}"
                               mc:Ignorable="d">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Metric Cards -->
            <RowDefinition Height="Auto" />
            <!-- Recent Activity Panel -->
            <RowDefinition Height="Auto" />
            <!-- Main space filler -->
            <RowDefinition Height="*" />
            <!-- Bottom Buttons -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Dashboard - Welcome to IndusTech System" 
                       Foreground="{DynamicResource TextPrimaryBrush}" 
                       FontSize="28" 
                       FontWeight="Bold" />
            <TextBlock Text="{Binding WelcomeMessage}" 
                       Foreground="{DynamicResource TextSecondaryBrush}" 
                       FontSize="14" 
                       Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="状态: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding IsBusy, StringFormat='忙碌/Busy: {0}'}" 
                           Foreground="{DynamicResource StatusAmberBrush}" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>

        <!-- Metric Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Instance ID -->
            <ContentControl Grid.Column="0" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterial Kind="Fingerprint" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Style="{DynamicResource LabelTextStyle}" Text="Instance ID" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Style="{DynamicResource ValueTextStyle}" Text="{Binding InstanceId}" />
                </StackPanel>
            </ContentControl>

            <!-- Card 2: Visit Count -->
            <ContentControl Grid.Column="2" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterial Kind="EyeOutline" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Style="{DynamicResource LabelTextStyle}" Text="Visit Count" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Style="{DynamicResource ValueTextStyle}" Text="{Binding VisitCount}" />
                </StackPanel>
            </ContentControl>

            <!-- Card 3: Last Refresh -->
            <ContentControl Grid.Column="4" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Style="{DynamicResource LabelTextStyle}" Text="Last Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Style="{DynamicResource ValueTextStyle}" FontSize="24" Text="{Binding LastRefreshAt}" />
                </StackPanel>
            </ContentControl>
        </Grid>

        <!-- Recent Activity Panel -->
        <ContentControl Grid.Row="2" Style="{DynamicResource CardStyle}" Margin="0,0,0,32">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <iconPacks:PackIconMaterial Kind="History" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Style="{DynamicResource LabelTextStyle}" Text="Recent Activity" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Border Background="{DynamicResource BgMainBrush}" CornerRadius="4" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="InformationOutline" Foreground="{DynamicResource StatusGreenBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding LastEditorMessage}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ContentControl>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="InfoDialogButton" 
                    Style="{DynamicResource OutlineButtonStyle}" 
                    Content="Show Info Dialog" 
                    Width="160" 
                    Margin="0,0,16,0">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MessageOutline" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            
            <Button x:Name="RefreshButton" 
                    Style="{DynamicResource PrimaryButtonStyle}" 
                    Content="Refresh Data" 
                    Width="160">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>
    </Grid>
</presentation:PrismReactiveView>
