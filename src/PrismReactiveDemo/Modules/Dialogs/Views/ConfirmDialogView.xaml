<presentation:PrismReactiveView x:Class="PrismReactiveDemo.Modules.Dialogs.Views.ConfirmDialogView"
                               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                               xmlns:presentation="clr-namespace:PrismReactiveDemo.Presentation.Core"
                               xmlns:vm="clr-namespace:PrismReactiveDemo.Modules.Dialogs.ViewModels"
                               x:TypeArguments="vm:ConfirmDialogViewModel">
    <Grid MinWidth="380" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="Bold"
                   Text="{Binding DialogTitle}" />
        <TextBlock Grid.Row="1"
                   Margin="0,14,0,14"
                   TextWrapping="Wrap"
                   Text="{Binding Message}" />
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="CancelButton"
                    Width="90"
                    Margin="0,0,10,0"
                    Content="取消" />
            <Button x:Name="ConfirmButton"
                    Width="90"
                    Content="确定" />
        </StackPanel>
    </Grid>
</presentation:PrismReactiveView>
