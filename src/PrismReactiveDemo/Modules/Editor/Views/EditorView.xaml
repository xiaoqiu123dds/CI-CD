<presentation:PrismReactiveView x:Class="PrismReactiveDemo.Modules.Editor.Views.EditorView"
                               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:prism="http://prismlibrary.com/"
                               xmlns:presentation="clr-namespace:PrismReactiveDemo.Presentation.Core"
                               xmlns:vm="clr-namespace:PrismReactiveDemo.Modules.Editor.ViewModels"
                               xmlns:design="clr-namespace:PrismReactiveDemo.Modules.Editor.Design"
                               x:TypeArguments="vm:EditorViewModel"
                               prism:ViewModelLocator.AutoWireViewModel="True"
                               d:DataContext="{d:DesignInstance Type=design:EditorDesignViewModel, IsDesignTimeCreatable=True}"
                               mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="26"
                       FontWeight="Bold"
                       Text="Editor" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding DocumentTitle, StringFormat=当前文档 / Document: {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding InstanceId, StringFormat=实例 Id / Instance Id: {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding FilePath, StringFormat=选择文件 / File Path: {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#92400E"
                       Text="{Binding IsDirty, StringFormat=未保存状态 / Is Dirty: {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#1D4ED8"
                       Text="{Binding ActivityState}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#047857"
                       Text="{Binding HeartbeatText, StringFormat=业务激活心跳 / Active Heartbeat: {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#B45309"
                       Text="{Binding IsBusy, StringFormat=忙碌状态 / Busy: {0}}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,12"
                    Orientation="Horizontal">
            <Button x:Name="PickFileButton"
                    Width="120"
                    Margin="0,0,10,0"
                    Content="选择文件" />
            <Button x:Name="SaveButton"
                    Width="120"
                    Content="保存内容" />
        </StackPanel>

        <TextBox x:Name="EditorTextBox"
                 Grid.Row="2"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="260"
                 Padding="12" />

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock TextWrapping="Wrap"
                       Text="本页示例点：KeepAlive=false、IsNavigationTarget=false、DestroyToken、IConfirmNavigationRequest、Interaction(OpenFileDialog 动态注册)、IActiveAware、ReactiveCommand 异常流。若文本包含 error，保存时会进入异常出口。" />
        </Border>
    </Grid>
</presentation:PrismReactiveView>
